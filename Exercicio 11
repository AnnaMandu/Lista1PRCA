using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Lista1Ex11
{
    internal class Program
    {
        static void Main(string[] args)
        {
            double nbase;
            double expoente;
            double resultado;

            Console.WriteLine("\n---------Exercício 11 da Lista 1---------\n");

            Console.Write("Digite o Valor da Base: ");
            nbase = double.Parse(Console.ReadLine());

            Console.Write("Digite o Valor do Expoente: ");
            expoente = double.Parse(Console.ReadLine());

            resultado = Math.Pow(nbase,expoente);

            Console.WriteLine("");
            Console.WriteLine("Resultado da exponencial: {0}", resultado);
        }
    }
}
