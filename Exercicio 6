using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Lista1Ex6
{
    internal class Program
    {
        static void Main(string[] args)
        {
            double valor1;
            double valor2;
            double mediaG;

            Console.WriteLine("\n---------Exercício 6 da Lista 1---------\n");

            Console.Write("Digite o Primeiro Valor: ");
